# Server
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Supabase (https://supabase.com → New Project → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Groq (https://console.groq.com → API Keys → Create API Key — FREE)
GROQ_API_KEY=your-groq-api-key

# Trends Microservice URL (deployed separately or locally)
TRENDS_SERVICE_URL=https://your-trends-service.railway.app

# Logging
LOG_LEVEL=info
